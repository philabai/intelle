# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://intelle.io

# Email (Brevo)
BREVO_API_KEY=your_brevo_api_key
ADMIN_EMAIL=hello@intelle.io

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Content automation
ANTHROPIC_API_KEY=sk-ant-...

# Buffer (reuse the same Buffer account / token used in Sathi.fit)
BUFFER_ACCESS_TOKEN=
BUFFER_ORGANIZATION_ID=
# Channel IDs for intelle.io's LinkedIn page + X account (find via /api/articles/buffer/profiles)
BUFFER_LINKEDIN_CHANNEL_ID=
BUFFER_TWITTER_CHANNEL_ID=

# Vercel Cron auth — generate a long random string
CRON_SECRET=

# ----------------------------------------------------------------------------
# RegWatch (lives at /regwatch/* in this same Vercel project)
# ----------------------------------------------------------------------------

# Brevo sender override for RegWatch transactional + critical-alert email.
# Falls back to ADMIN_EMAIL when unset.
BREVO_SENDER_EMAIL=

# Voyage AI — voyage-3-large embeddings for regulatory_items (Phase 1)
VOYAGE_API_KEY=

# ----------------------------------------------------------------------------
# intelleLLM — self-hosted, privacy-isolated AI for CUSTOMER documents.
# Leave INTELLELLM_ENABLED unset/false: customer-doc AI keeps using the existing
# providers (Claude/Voyage/OpenAI) exactly as today. Set it to "true" ONLY once
# the self-hosted endpoints below are live — then customer data routes to
# intelleLLM ONLY and fails closed (never falls back to a third party).
# ----------------------------------------------------------------------------
INTELLELLM_ENABLED=false
# Chat/vision model, fronted by an Anthropic-Messages-compatible endpoint
# (e.g. a LiteLLM proxy over vLLM). The app keeps using the Anthropic SDK.
INTELLELLM_BASE_URL=
INTELLELLM_API_KEY=
INTELLELLM_MODEL=
# Self-hosted embedder for customer-doc semantic search (OpenAI /embeddings shape,
# e.g. TEI / Infinity). Dim is baked into the DB column + index — set before backfill.
INTELLE_EMBED_BASE_URL=
INTELLE_EMBED_API_KEY=
INTELLE_EMBED_MODEL=
INTELLE_EMBED_DIM=1024
# Self-hosted ASR for evidence video + reviewer voice notes (OpenAI
# /audio/transcriptions shape, e.g. faster-whisper-server).
INTELLE_ASR_BASE_URL=
INTELLE_ASR_API_KEY=
INTELLE_ASR_MODEL=whisper-1

# Stripe Billing — RegWatch tier upgrades (Phase 1.9)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Create Products + Prices in Stripe Dashboard, then paste the Price IDs here.
# Tiers without a configured price won't be available for checkout.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# RegWatch Web Push (VAPID) — Phase 1.7
# Generate once with:  npx web-push generate-vapid-keys
# NEXT_PUBLIC_* is intentionally exposed to the browser; the private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@intelle.io
